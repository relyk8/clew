# Clew local machine config — template. Copy to `.env` and fill in real values:
#   cp .env.example .env
# `.env` is gitignored; never commit real paths, hostnames, or credentials.
#
# Load into your shell before running the pipeline / CAPE client, e.g.:
#   set -a; source .env; set +a

# capa rules checkout and signatures (Channel 0). Consumed by clew/pipeline.py.
# capa 9.4.0 ships its sigs in the source tree, not the installed package.
CLEW_CAPA_RULES=/path/to/capa-rules
CLEW_CAPA_SIGS=/path/to/capa-src/sigs

# CAPE apiv2 base URL (Channel 3 client, clew/cape_client.py).
CAPE_BASE_URL=http://127.0.0.1:8000
